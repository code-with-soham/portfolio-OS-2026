# ============================================
# Portfolio OS 2026 — Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values

PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Contact form recipient
CONTACT_EMAIL=your-email@example.com

# SMTP Configuration (optional — for sending contact form emails)
# If not configured, contact messages are logged to the console
# Example with Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
